# Directus CMS Configuration
# Copy this file to .env and fill in your actual values

# Directus Instance URL (publicly accessible)
PUBLIC_DIRECTUS_URL=https://directus.kaihaan.com

# Directus API Token (static token for read access)
# Generate this in Directus: Settings > Access Tokens > Create Token
DIRECTUS_TOKEN=your-static-api-token-here

# Service-account token for the members area (server-only, REQUIRED for /members/*)
# Backs the personal iCal feed and feed-token rotation. Belongs to a dedicated
# Directus service account that can (a) read directus_users filtered by feed_token
# and (b) read all events (public + members-only). Never exposed to the client.
# Generate in Directus: Settings > Access Tokens > Create Token.
DIRECTUS_ADMIN_TOKEN=your-service-account-token-here
